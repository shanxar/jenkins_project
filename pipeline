pipeline {
    agent any

    parameters {
        string(name: 'NAME', defaultValue: 'John', description: 'Enter name')
        string(name: 'TIMES', defaultValue: '3', description: 'Number of greetings')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch:'main', url:'https://github.com/shanxar/jenkins_project'
            }
        }
        
        stage("Create Virtual Enviroment"){
            steps{
                sh "python3 -m venv venv"
        
            }
        }
        stage('Install Dependencies'){
            steps{
                sh "venv/bin/python  -m pip install -r requirements.txt"
            }
        }

        stage('Run Python Script') {
            steps {
                sh "venv/bin/python  app.py --name ${params.NAME} --times ${params.TIMES}"
            }
        }
    }

    post {
        success {
            echo "Execution successful "
        }
        failure {
            echo "Execution failed "
            
        }
    }
}